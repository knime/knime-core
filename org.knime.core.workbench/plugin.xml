<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>
   <extension-point id="org.knime.core.workbench.mount" name="KNIME Mount Point Definition" schema="schema/org.knime.core.workbench.mount.exsd"/>
   <extension
         point="org.knime.core.workbench.mount">
      <MountPointDefinition
            defaultMountID="LOCAL"
            settingsHandlerClass="org.knime.core.workbench.mountpoint.contribution.local.LocalWorkspaceMountPointSettingsHandler"
            supportsMultipleInstances="false"
            typeIdentifier="org.knime.workbench.explorer.workspace">
      </MountPointDefinition>
      <MountPointDefinition
            defaultMountID="knime-temp-space"
            settingsHandlerClass="org.knime.core.workbench.mountpoint.contribution.temp.TempSpaceMountPointSettingsHandler"
            supportsMultipleInstances="false"
            typeIdentifier="com.knime.explorer.tempspace">
      </MountPointDefinition>
   </extension>


</plugin>
